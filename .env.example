# Elasticsearch
ES_USER=your_es_username
ES_PASSWORD=your_es_password
ES_URL=http://localhost:9200
ES_HOST=localhost
ES_PORT=9200
ES_API_KEY=your_es_api_key

# Embedding Service (OpenAI-compatible API)
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=http://localhost:8000/v1/

# LLM for generation testing (OpenAI-compatible API)
OPENAI_ENGINE=your_model_name
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=http://localhost:8001/v1

# LLM for generation evaluation (used in test_retrieval_pipeline.py)
GPT4O_MINI_OPENAI_API_KEY=your_api_key
GPT4O_MINI_OPENAI_RESOURCE_ENDPOINT=https://your-openai-endpoint/v1
GPT4O_MINI_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# VLM Service (OpenAI-compatible API, used by marker_processor for image captioning)
VLM_API_KEY=your_vlm_api_key
VLM_BASE_URL=http://localhost:5013/v1

# Azure OpenAI (used by RAGAS evaluation metrics)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_VERSION=2023-03-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-endpoint.openai.azure.com

# Azure Embeddings (used by RAGAS evaluation metrics)
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_EMBEDDING_API_VERSION=2023-05-15
AZURE_EMBEDDING_ENDPOINT=https://your-azure-embedding-endpoint.openai.azure.com
